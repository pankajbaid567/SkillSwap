DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?schema=public"
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"
REDIS_URL="redis://localhost:6380"
PORT=5001
# Default window 15m; max requests per IP per window (raise for heavy local dev / React Strict Mode)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
RATE_LIMIT_DISABLED=false
# Optional: comma-separated origins. If omitted, localhost/127.0.0.1 origins are allowed in development.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:1575,http://127.0.0.1:1575

# After migrations: from backend/, run `npm run db:seed` for mock users (alice@… through dan@… @ seed.skillswap.local, password Password123!). Re-seed: `npx prisma migrate reset`.
