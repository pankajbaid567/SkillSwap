generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  avgRating    Decimal  @default(0.0) @db.Decimal(3, 2)
  totalSwaps   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile           Profile?
  refreshTokens     RefreshToken[]
  skills            UserSkill[]
  availabilitySlots AvailabilitySlot[]
  matchesAsUser1    Match[]            @relation("MatchUser1")
  matchesAsUser2    Match[]            @relation("MatchUser2")
}

model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  displayName String?
  bio         String?
  avatarUrl   String?
  location    String?
  timezone    String?
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SkillType {
  offer
  want
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model SkillCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  parentId  String?  @db.Uuid
  createdAt DateTime @default(now())

  parent   SkillCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children SkillCategory[] @relation("CategoryHierarchy")
  skills   Skill[]
}

model Skill {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  categoryId  String   @db.Uuid
  createdAt   DateTime @default(now())

  category   SkillCategory @relation(fields: [categoryId], references: [id])
  userSkills UserSkill[]
}

model UserSkill {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  skillId          String           @db.Uuid
  type             SkillType
  proficiencyLevel ProficiencyLevel
  description      String?
  endorsementCount Int              @default(0)
  isVerified       Boolean          @default(false)
  addedAt          DateTime         @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model AvailabilitySlot {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  dayOfWeek   Int      @db.SmallInt // 0-6
  slotStart   DateTime @db.Time
  slotEnd     DateTime @db.Time
  isRecurring Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
}

model Match {
  id                 String   @id @default(uuid()) @db.Uuid
  userId1            String   @db.Uuid
  userId2            String   @db.Uuid
  compatibilityScore Decimal  @db.Decimal(5, 4)
  strategyUsed       String
  sharedInterests    Json?
  isActive           Boolean  @default(true)
  status             String   @default("pending") // pending | accepted | declined | expired
  matchedAt          DateTime @default(now())
  expiresAt          DateTime

  user1 User @relation("MatchUser1", fields: [userId1], references: [id], onDelete: Cascade)
  user2 User @relation("MatchUser2", fields: [userId2], references: [id], onDelete: Cascade)

  @@index([userId1])
  @@index([userId2])
  @@index([status])
}
